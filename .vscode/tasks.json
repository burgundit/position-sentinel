{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run server",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": ["server.py"],
      "isBackground": true,
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Check Python syntax",
      "type": "shell",
      "command": ".venv\\Scripts\\python.exe",
      "args": ["-m", "py_compile", "server.py", "backend\\server.py", "backend\\symbols.py", "main.py"],
      "problemMatcher": "$python"
    },
    {
      "label": "Check JS syntax",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "tools\\check-js.ps1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Check all",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Check Python syntax",
        "Check JS syntax",
        "Git status"
      ],
      "problemMatcher": []
    },
    {
      "label": "Git status",
      "type": "shell",
      "command": "git",
      "args": ["status", "--short", "--branch"],
      "problemMatcher": []
    }
  ]
}
